# GEMINI_API_KEY: Required for native Gemini AI API calls.
# If configured, live model requests will connect to Google Gemini.
GEMINI_API_KEY=""

# APP_URL: The self-referential URL where this application is hosted.
# Used for PWA service links and API endpoints mapping.
APP_URL="http://localhost:3000"

# NODE_ENV: The runtime environment mode ('development' or 'production').
# Governs HMR configs and stack trace verbosity.
NODE_ENV="development"

# --- CUSTOM OPENAI ENDPOINT FALLBACK SETTINGS (OPTIONAL SERVER VARIABLES) ---
# Note: Users can save and load profiles inside the settings panel. These server-side
# fallbacks are used if no active connection profile is loaded in the browser.

# CUSTOM_OPENAI_BASE_URL: The default fallback base URL for custom LLMs.
# Example: https://api.openrouter.ai or http://localhost:11434 (local Ollama)
CUSTOM_OPENAI_BASE_URL=""

# CUSTOM_OPENAI_API_KEY: The default server-side API Key for the custom endpoint.
# Keep empty if you only intend to configure keys transiently in the client.
CUSTOM_OPENAI_API_KEY=""

# CUSTOM_OPENAI_MODEL: The default fallback model for the custom endpoint.
# Example: deepseek/deepseek-v4-flash or gpt-4o
CUSTOM_OPENAI_MODEL=""
